{
  "name": "rental-webapp",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "clean:next": "node scripts/clean-next-cache.mjs --force",
    "predev": "node scripts/clean-next-cache.mjs",
    "dev": "next dev",
    "prebuild": "node scripts/clean-next-cache.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "npm run typecheck",
    "typecheck": "tsc --noEmit",
    "db:generate": "node -e \"console.log('No generation step required for hosted JSON document store.')\"",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:push": "node scripts/db-migrate.mjs",
    "email:check": "node scripts/check-email-config.mjs",
    "email:probe": "node scripts/check-email-config.mjs --probe",
    "test": "vitest run --pool=threads --maxWorkers=1"
  },
  "dependencies": {
    "@vercel/blob": "^2.4.0",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^16.6.1",
    "fast-check": "^4.7.0",
    "jose": "^5.9.6",
    "lucide-react": "^0.511.0",
    "next": "^15.5.19",
    "postgres": "^3.4.9",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.3",
    "stripe": "^22.2.0",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.4",
    "@types/node": "^22.14.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "tailwindcss": "^4.1.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
