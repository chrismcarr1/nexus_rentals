DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
AUTH_SECRET="change-this-to-a-long-random-string"
SYSTEM_ADMIN_EMAIL="admin@example.com"
APP_URL="http://localhost:3000"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Tenant screening providers. Use mock mode locally until sandbox credentials are configured.
CHECKR_API_KEY=""
CHECKR_PACKAGE_SLUG=""
CHECKR_WEBHOOK_SECRET=""
CHECKR_MOCK_MODE="true"
PLAID_CLIENT_ID=""
PLAID_SECRET=""
# Retained for legacy Plaid accounts; modern Link does not use a public key.
PLAID_PUBLIC_KEY=""
PLAID_ENV="sandbox"
PLAID_WEBHOOK_SECRET=""
PLAID_MOCK_MODE="true"
NEXT_PUBLIC_PLAID_ENV="sandbox"
# Dedicated encryption key for Plaid access/user tokens. Use a long random value in production.
SCREENING_ENCRYPTION_KEY=""
# Optional decision-support thresholds. These never make the landlord's final decision.
SCREENING_APPROVED_MAX_RISK="25"
SCREENING_HIGH_RISK_MIN="61"
SCREENING_STRONG_INCOME_RATIO="3"
SCREENING_REVIEW_INCOME_RATIO="2.5"
SCREENING_MINIMUM_INCOME_RATIO="2"
# Required for AI photo maintenance request drafting.
OPENAI_API_KEY=""
# Optional. Defaults to OpenAI's flagship vision-capable model.
OPENAI_MAINTENANCE_MODEL="gpt-5.5"
# Required in Vercel production for persistent uploads. Leave blank locally to use public/uploads.
BLOB_READ_WRITE_TOKEN=""
# Required to send tenant invite and password reset emails through Cloudflare Email Service.
CLOUDFLARE_EMAIL_FROM="Nexus Rentals <no-reply@yourdomain.com>"
# Option A: call a Cloudflare Worker with an EMAIL or SEND_EMAIL binding.
CLOUDFLARE_EMAIL_WORKER_URL=""
CLOUDFLARE_EMAIL_WORKER_SECRET=""
# Option B: call Cloudflare Email Service REST API directly.
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_EMAIL_API_TOKEN=""
